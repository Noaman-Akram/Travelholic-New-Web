# Travelholic — environment variables
# Copy to .env.local and fill in values. Public vars are exposed to the browser.

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en

# WhatsApp — REVIEW: pending number from team. Until set, FAB renders aria-disabled.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Analytics (Phase 4) — leave blank to disable
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Booking webhook — POST target for direct booking leads.
# Used as fallback when Hostify direct-reservation API isn't wired yet.
BOOKING_WEBHOOK_URL=

# SuperPay payment iframe — server-only except the public site URL above.
# Keep SUPERPAY_SECURE_HASH_KEY private; it signs order amounts.
SUPERPAY_BASE_URL=https://merchant.super-pay.com
SUPERPAY_MERCHANT_CODE=
SUPERPAY_API_KEY=
SUPERPAY_SECURE_HASH_KEY=
SUPERPAY_PAYMENT_MODE=AUTH_AND_CAP

# Newsletter — Mailchimp / Brevo / Loops
NEWSLETTER_API_KEY=
NEWSLETTER_LIST_ID=

# Hostify PMS — listings + reservations source.
# Server-only (no NEXT_PUBLIC_) so the key never reaches the browser bundle.
# Get a key from your Hostify account; rotate any key that's been pasted in
# chat or screenshots since transcripts may be retained.
HOSTIFY_API_KEY=
HOSTIFY_API_BASE=https://api-rms.hostify.com

# Booking subdomain (Hostify-powered) — Book-direct CTAs deep-link here.
NEXT_PUBLIC_BOOKING_SITE=https://book.travelholiceg.com

# USD↔EGP rate used for displaying Hostify USD prices in EGP.
# REVIEW: replace with a live FX feed in production. Default ~50 EGP/USD.
NEXT_PUBLIC_EGP_PER_USD=50
