# Travelholic — environment variables
# Copy to .env.local and fill in values. Public vars are exposed to the browser.

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en

# WhatsApp — REVIEW: pending number from team. Until set, FAB renders aria-disabled.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Analytics (Phase 4) — leave blank to disable
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Booking webhook — POST target for direct booking leads.
# Used as fallback when Hostify direct-reservation API isn't wired yet.
BOOKING_WEBHOOK_URL=

# Newsletter — Mailchimp / Brevo / Loops
NEWSLETTER_API_KEY=
NEWSLETTER_LIST_ID=

# Hostify PMS — listings + reservations source.
# Server-only (no NEXT_PUBLIC_) so the key never reaches the browser bundle.
# Get a key from your Hostify account; rotate any key that's been pasted in
# chat or screenshots since transcripts may be retained.
HOSTIFY_API_KEY=
HOSTIFY_API_BASE=https://api-rms.hostify.com

# Booking subdomain (Hostify-powered) — Book-direct CTAs deep-link here.
NEXT_PUBLIC_BOOKING_SITE=https://book.travelholiceg.com

# USD↔EGP — live rate from Frankfurter (ECB), with er-api + exchangerate.host
# as fallbacks, plus a disk-persisted last-good cache. Refreshed every 6 hours.
# Both vars below are escape hatches and should normally stay unset.
#   EGP_PER_USD_OVERRIDE — pin a manual rate (admin escape hatch)
#   EGP_PER_USD_FALLBACK — final static value if all providers fail AND
#                          there's no last-good cache. Default 50.
EGP_PER_USD_OVERRIDE=
EGP_PER_USD_FALLBACK=50

# Debug endpoint: GET /api/fx returns current rate + source.

# SuperPay payment gateway. Sandbox creds shipped here are public test
# values from the integration guide; rotate to LIVE before launch.
SUPERPAY_BASE_URL=https://merchant.super-pay.com
SUPERPAY_MERCHANT_CODE=SUPER0001582_TST
SUPERPAY_API_KEY=U2vpMIEpCo
SUPERPAY_SECRET_KEY=ZDAAuQOEuS

# Public origin used to build SuperPay return + cancel URLs.
# Locally: http://localhost:3000  •  Prod: https://travelholiceg.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
