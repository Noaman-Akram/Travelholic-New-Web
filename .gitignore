# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files: ignore all by default, but always commit the .example template.
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Travelholic local Node install
.tools/

# Runtime caches: FX last-good rates + SuperPay pending orders.
# These are written by the server at runtime and must never be committed.
.cache/

# Playwright artifacts
/test-results/
/playwright-report/
/playwright/.cache/

# Claude Code per-machine permissions
.claude/settings.local.json

# Vercel + worktrees
.claude/worktrees/
super pay intg refrence docs/
