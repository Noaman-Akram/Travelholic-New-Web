{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "rules": {
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/\\b(ml|mr|pl|pr)-(0|0\\.5|1|1\\.5|2|2\\.5|3|3\\.5|4|5|6|7|8|9|10|11|12|14|16|20|24|28|32|36|40|44|48|52|56|60|64|72|80|96|auto|px)\\b/]",
        "message": "Use logical properties (ms-/me-/ps-/pe-) instead of physical (ml-/mr-/pl-/pr-) for RTL parity."
      },
      {
        "selector": "Literal[value=/\\b(left|right)-(0|0\\.5|1|1\\.5|2|2\\.5|3|3\\.5|4|5|6|7|8|9|10|11|12|14|16|20|24|28|32|36|40|44|48|auto|full|px)\\b/]",
        "message": "Use logical properties (start-/end-) instead of physical (left-/right-) for RTL parity."
      }
    ]
  },
  "overrides": [
    {
      "files": ["components/ui/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-syntax": "off"
      }
    }
  ]
}
